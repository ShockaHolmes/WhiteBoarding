        lang_display = LANGUAGE_DISPLAY.get(language, language)
        scenario = Scenario(
            level=level,
            category=display_name,
            title=f"Code Write: {display_name} ({lang_display})",
            prompt=f"Code write drill — {display_name} — {level.title()} — {lang_display}",
            steps=questions,
        )

        print_banner(f"Code Write: {display_name}", f"Level: {level.title()}  |  Language: {lang_display}")
        completed, _ = play_scenario(scenario, state, category_stats, answer_handler=ask_step_code)

        score = state["score"]
        possible = state["possible"]
        percent = round((score / possible) * 100, 1) if possible else 0

        print_panel(
            "Code Write Session Summary",
            [
                f"Topic:    {color_text(display_name, BOLD, CYAN)}",
                f"Level:    {level_badge(level)}",
                f"Language: {color_text(lang_display, BOLD, MAGENTA)}",
                f"Score:    {format_score(score, possible)}  ({color_text(f'{percent}%', BOLD, GREEN if percent >= 80 else YELLOW)})",
                f"Hints:    {state['hints_used']}",
                f"Hearts:   {hearts_text(state['hearts'])}",
            ],
            accent=GREEN,
        )

        if percent == 100:
            print(color_text("Perfect score! Your code writing is sharp.", BOLD, GREEN))
        elif percent >= 80:
            print(color_text("Great work! You are writing strong interview answers.", BOLD, CYAN))
        elif percent >= 60:
            print(color_text("Good effort. Keep tightening your code syntax and recall.", BOLD, YELLOW))
        else:
            print(color_text("Keep practicing. Writing each answer builds stronger retention.", BOLD, RED))

        leaderboard = update_leaderboard(
            f"{name} [CodeWrite:{display_name}]",
            score,
            possible,
            level,
            state["hints_used"],
        )
        print_leaderboard(leaderboard)

        again = input(color_text("\nPractice another code-write topic? (y/n): ", BOLD)).strip().lower()
        if again != "y":
            print(color_text("Returning to main menu.", BOLD, BLUE))
            return


