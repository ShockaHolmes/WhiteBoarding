def build_easy_add(func_name: str, delta: int) -> Scenario:
    prompt = f"Write a function named {func_name}(n) that returns n + {delta}."
    steps = [
        make_step(
            "1) What type of problem is this?",
            "Function + arithmetic",
            ["Class design", "String parsing", "Dictionary lookup"],
            "You are writing a small reusable piece of logic that performs math.",
            "This is a function problem using arithmetic."
        ),
        make_step(
            "2) What should go first in the solution?",
            "def",
            ["class", "str", "int"],
            "Most interview coding tasks begin by defining a function.",
            "You should start with def because you are creating a function."
        ),
        make_step(
            "3) What data type should n be?",
            "int",
            ["str", "list", "dict"],
            "The prompt says n is a number being added to another number.",
            "n should be an int because we are doing integer arithmetic."
        ),
        make_step(
            "4) Which function header is correct?",
            f"def {func_name}(n):",
            [f"def {func_name}:", f"class {func_name}(n):", f"def {func_name}(n)"],
            "Look for def, the function name, the parameter, and the colon.",
            "A valid Python function header needs def, the name, parentheses, and a colon."
        ),
        make_step(
            "5) Which line belongs inside the function?",
            f"return n + {delta}",
            [f"print(n + {delta})", f"n + {delta}", f"return '{delta}'"],
            "Interview solutions usually return the result instead of printing it.",
            "The function should return the computed value."
        ),
    ]
    return Scenario("easy", "Math", f"Add {delta}", prompt, steps)


