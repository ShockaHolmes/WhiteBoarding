def _map_param_type(param: str, language: str) -> str:
    p = param.strip()
    if language == "java":
        if p in {"n", "num", "target", "start", "i"}:
            return "int"
        if p in {"nums", "items"}:
            return "int[]"
        if p in {"text", "name", "ch"}:
            return "String"
        return "Object"
    if language == "csharp":
        if p in {"n", "num", "target", "start", "i"}:
            return "int"
        if p in {"nums", "items"}:
            return "int[]"
        if p in {"text", "name", "ch"}:
            return "string"
        return "object"
    return ""


def _infer_return_type(func_name: str, params: List[str], language: str) -> str:
    lower_name = func_name.lower()

    if lower_name.startswith(("is_", "has_")):
        return "boolean" if language == "java" else "bool"
    if lower_name.startswith(("count_", "sum_", "find_", "binary_search_", "add_")):
        return "int"
    if lower_name.startswith(("first_char_", "greet_", "reverse_")):
        return "String" if language == "java" else "string"
    if lower_name.startswith("two_sum_"):
        return "int[]"
    if params == ["text"]:
        return "String" if language == "java" else "string"
    return "Object" if language == "java" else "object"


def _convert_def_header(match: re.Match, language: str) -> str:
    func_name = match.group(1)
    raw_params = match.group(2).strip()
    params = [] if not raw_params else [p.strip() for p in raw_params.split(",") if p.strip()]
    if language == "java":
        typed = [f"{_map_param_type(p, language)} {p}" for p in params]
        return_type = _infer_return_type(func_name, params, language)
        return f"public static {return_type} {func_name}({', '.join(typed)}) {{"
    if language == "csharp":
        typed = [f"{_map_param_type(p, language)} {p}" for p in params]
        return_type = _infer_return_type(func_name, params, language)
        return f"public static {return_type} {func_name}({', '.join(typed)}) {{"
    return match.group(0)


