def generate_hard_pool() -> List[Scenario]:
    pool = []

    for i in range(1, 25):
        pool.append(build_hard_class_counter(f"Counter{i}"))
        pool.append(build_hard_two_sum(f"two_sum_{i}"))
        pool.append(build_hard_binary_search(f"binary_search_{i}"))
        pool.append(build_hard_valid_parentheses(f"is_balanced_{i}"))
        pool.append(build_hard_has_duplicate(f"has_duplicate_{i}"))

    return pool


def get_pool(level: str) -> List[Scenario]:
    if level == "easy":
        return generate_easy_pool()
    if level == "medium":
        return generate_medium_pool()
    return generate_hard_pool()


def play_scenario(
    scenario: Scenario,
    state: Dict,
    category_stats: Dict[str, Dict[str, int]],
) -> None:
    print("\n" + "=" * 72)
    print(f"INTERVIEW SCENARIO: {scenario.title}")
    print(f"Category: {scenario.category}")
    print("-" * 72)
    print(f"Prompt: {scenario.prompt}")
    print("-" * 72)
    print(f"Hearts: {hearts_text(state['hearts'])}")
    print(f"Current Score: {state['score']}/{state['possible']}")
    print(f"Current Streak: {state['streak']}")
    print("-" * 72)

    scenario_correct = 0
    scenario_possible = 0

    if scenario.category not in category_stats:
        category_stats[scenario.category] = {"earned": 0, "possible": 0}

    for step in scenario.steps:
        is_correct, hints_used = ask_step(step)

        state["hints_used"] += hints_used
        state["possible"] += 10
        scenario_possible += 10
        category_stats[scenario.category]["possible"] += 10

        if is_correct:
            state["score"] += 10
            scenario_correct += 10
            category_stats[scenario.category]["earned"] += 10
            state["streak"] += 1

            if state["streak"] > 0 and state["streak"] % 3 == 0:
                state["score"] += 5
                state["bonus"] += 5
                print("Streak bonus: +5 points")
        else:
            state["hearts"] = max(0, state["hearts"] - 1)
            state["streak"] = 0
            print(f"Heart lost. Hearts now: {hearts_text(state['hearts'])}")

    if scenario_correct == scenario_possible and state["hearts"] < STARTING_HEARTS:
        state["hearts"] += 1
        print("Perfect scenario. You regained 1 heart.")

    print("\nScenario complete.")
    print(f"Scenario Score: {scenario_correct}/{scenario_possible}")
    print(f"Overall Score: {state['score']}/{state['possible']}")
    print(f"Hearts: {hearts_text(state['hearts'])}")


def print_category_breakdown(category_stats: Dict[str, Dict[str, int]]) -> None:
    print("\n" + "=" * 72)
    print("CATEGORY BREAKDOWN")
    print("=" * 72)
    for category, stats in sorted(category_stats.items()):
        earned = stats["earned"]
        possible = stats["possible"]
        percent = (earned / possible * 100) if possible else 0
        print(f"{category:<15} {earned:>3}/{possible:<3}  {percent:>6.1f}%")


def play_game() -> None:
    print("=" * 72)
    print("WHITEBOARD INTERVIEW GAME")
    print("=" * 72)
    print("You will play through 10 interview-style coding scenarios.")
    print("Each scenario makes you work through the problem step by step.")
    print("Type H at any step if you want a hint.\n")

    name = ask_player_name()
    level = ask_level()
    pool = get_pool(level)

    if len(pool) < 100:
        raise ValueError(f"{level} level must have at least 100 prepared scenarios.")

    selected = random.sample(pool, SESSION_SCENARIOS)

    state = {
        "score": 0,
        "possible": 0,
        "bonus": 0,
        "streak": 0,
        "hearts": STARTING_HEARTS,
        "hints_used": 0,
    }

    category_stats: Dict[str, Dict[str, int]] = {}

    for i, scenario in enumerate(selected, start=1):
        print(f"\n\n########## Scenario {i} of {SESSION_SCENARIOS} ##########")
        play_scenario(scenario, state, category_stats)

    percent = round((state["score"] / state["possible"]) * 100, 1) if state["possible"] else 0

    print("\n" + "=" * 72)
    print("SESSION COMPLETE")
    print("=" * 72)
    print(f"Player: {name}")
    print(f"Level: {level.title()}")
    print(f"Final Score: {state['score']}/{state['possible']}")
    print(f"Percent: {percent}%")
    print(f"Bonus Points Earned: {state['bonus']}")
    print(f"Hints Used: {state['hints_used']}")
    print(f"Hearts Left: {state['hearts']} {hearts_text(state['hearts'])}")

    if percent >= 90:
        print("Excellent interview-style performance.")
    elif percent >= 75:
        print("Strong work. You are building real whiteboarding muscle.")
    elif percent >= 60:
        print("Good effort. Review the explanations and run it again.")
    else:
        print("Keep practicing. The step-by-step format will help you improve quickly.")

    print_category_breakdown(category_stats)

    leaderboard = update_leaderboard(name, state["score"], state["possible"], level, state["hints_used"])
    print_leaderboard(leaderboard)

    again = input("\nPlay again? (y/n): ").strip().lower()
    if again == "y":
        print()
        play_game()


if __name__ == "__main__":
    play_game()