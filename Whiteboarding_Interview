import json
import os
import random
from dataclasses import dataclass
from typing import List, Dict


LEADERBOARD_FILE = "whiteboard_leaderboard.json"
SESSION_SCENARIOS = 10
STARTING_HEARTS = 12


@dataclass
class StepQuestion:
    prompt: str
    choices: List[str]
    answer_index: int
    hint: str
    explanation: str


@dataclass
class Scenario:
    level: str
    category: str
    title: str
    prompt: str
    steps: List[StepQuestion]


def make_step(prompt: str, correct: str, wrongs: List[str], hint: str, explanation: str) -> StepQuestion:
    clean_wrongs = []
    for item in wrongs:
        if item != correct and item not in clean_wrongs:
            clean_wrongs.append(item)

    choices = [correct] + clean_wrongs[:3]
    random.shuffle(choices)
    answer_index = choices.index(correct)
    return StepQuestion(
        prompt=prompt,
        choices=choices,
        answer_index=answer_index,
        hint=hint,
        explanation=explanation,
    )


def hearts_text(hearts: int) -> str:
    full = "❤️" * max(0, hearts)
    empty = "🖤" * max(0, STARTING_HEARTS - hearts)
    return full + empty


def load_leaderboard() -> List[Dict]:
    if not os.path.exists(LEADERBOARD_FILE):
        return []
    try:
        with open(LEADERBOARD_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            return data if isinstance(data, list) else []
    except (json.JSONDecodeError, OSError):
        return []


def save_leaderboard(entries: List[Dict]) -> None:
    with open(LEADERBOARD_FILE, "w", encoding="utf-8") as f:
        json.dump(entries[:10], f, indent=2)


def update_leaderboard(name: str, score: int, possible: int, level: str, hints_used: int) -> List[Dict]:
    percent = round((score / possible) * 100, 1) if possible else 0
    entries = load_leaderboard()
    entries.append({
        "name": name,
        "score": score,
        "possible": possible,
        "percent": percent,
        "level": level,
        "hints_used": hints_used
    })
    entries.sort(key=lambda x: (x["score"], x["percent"], -x["hints_used"]), reverse=True)
    save_leaderboard(entries)
    return entries[:10]


def print_leaderboard(entries: List[Dict]) -> None:
    print("\n" + "=" * 72)
    print("LEADERBOARD")
    print("=" * 72)
    if not entries:
        print("No leaderboard entries yet.")
        return
    for i, entry in enumerate(entries, start=1):
        print(
            f"{i:>2}. {entry['name']:<15} "
            f"Level: {entry['level']:<6} "
            f"Score: {entry['score']}/{entry['possible']:<4} "
            f"Percent: {entry['percent']:>5}% "
            f"Hints: {entry['hints_used']}"
        )


def ask_level() -> str:
    while True:
        level = input("Choose a level (easy / medium / hard): ").strip().lower()
        if level in {"easy", "medium", "hard"}:
            return level
        print("Please type easy, medium, or hard.")


def ask_player_name() -> str:
    name = input("Enter your name for the leaderboard: ").strip()
    return name if name else "Player"


def ask_step(step: StepQuestion) -> tuple[bool, int]:
    letters = "ABCD"
    hint_count = 0
    used_hint_once = False

    print("\n" + step.prompt)
    for i, choice in enumerate(step.choices):
        print(f"  {letters[i]}. {choice}")

    while True:
        answer = input("Choose A, B, C, or D. Type H for a hint: ").strip().upper()
        if answer == "H":
            print(f"\nHint: {step.hint}")
            if not used_hint_once:
                hint_count += 1
                used_hint_once = True
            continue
        if answer in letters[:len(step.choices)]:
            selected = letters.index(answer)
            is_correct = selected == step.answer_index
            if is_correct:
                print("Correct.")
            else:
                correct_letter = letters[step.answer_index]
                print(f"Incorrect. Correct answer: {correct_letter}. {step.choices[step.answer_index]}")
            print(f"Why: {step.explanation}")
            return is_correct, hint_count
        print("Please enter A, B, C, D, or H.")


