def localize_step(step: StepQuestion, language: str) -> StepQuestion:
    if language == "python":
        return step
    return StepQuestion(
        prompt=localize_text(step.prompt, language),
        choices=[localize_text(choice, language) for choice in step.choices],
        answer_index=step.answer_index,
        hint=localize_text(step.hint, language),
        explanation=localize_text(step.explanation, language),
    )


def localize_scenario(scenario: Scenario, language: str) -> Scenario:
    if language == "python":
        return scenario
    category_label = f"{LANGUAGE_DISPLAY[language]} {scenario.category}"
    return Scenario(
        level=scenario.level,
        category=category_label,
        title=f"{scenario.title} ({LANGUAGE_DISPLAY[language]})",
        prompt=localize_text(scenario.prompt, language),
        steps=[localize_step(step, language) for step in scenario.steps],
    )


def ask_step(step: StepQuestion, scenario_prompt: str) -> tuple[bool, int, bool]:
    letters = "ABCD"
    hint_count = 0
    used_hint_once = False

    print(color_text("\n─" * 0))
    print_rule("─", MAGENTA)
    print(color_text("Problem", BOLD, MAGENTA))
    print(color_text(scenario_prompt, BLUE))
    print_rule("─", DIM)
    print(color_text(step.prompt, BOLD))
    print()
    for i, choice in enumerate(step.choices):
        print(f"  {color_text(f'{letters[i]}.', BOLD, CYAN)} {choice}")
    print()

    while True:
        answer = input("Your choice (A/B/C/D, H for hint, Q to quit/save): ").strip().upper()
        if answer == "Q":
            return False, hint_count, True
        if answer == "H":
            print(f"\nHint: {step.hint}\n")
            if not used_hint_once:
                hint_count += 1
                used_hint_once = True
            continue
        if answer in letters[:len(step.choices)]:
            selected = letters.index(answer)
            is_correct = selected == step.answer_index
            if is_correct:
                print(f"\n{GREEN}Correct.{RESET}")
            else:
                correct_letter = letters[step.answer_index]
                print(
                    f"\n{YELLOW}Incorrect. Correct answer: {correct_letter}. "
                    f"{step.choices[step.answer_index]}{RESET}"
                )
            print(f"Why: {step.explanation}\n")
            return is_correct, hint_count, False
        print("\nPlease enter A, B, C, D, H, or Q.\n")


def _normalize_code_answer(text: str) -> str:
    # Normalize whitespace and casing so equivalent code formatting is accepted.
    return " ".join(text.strip().lower().split())


NUMBER_WORD_MAP = {
    "zero": "0",
    "one": "1",
    "two": "2",
    "three": "3",
    "four": "4",
    "five": "5",
    "six": "6",
    "seven": "7",
    "eight": "8",
    "nine": "9",
    "ten": "10",
    "eleven": "11",
    "twelve": "12",
}

SYNONYM_WORD_MAP = {
    "inner": "contains",
    "inside": "contains",
    "within": "contains",
    "includes": "contains",
    "include": "contains",
    "nested": "contains",
    "method": "function",
    "func": "function",
    "arrays": "list",
    "array": "list",
    "lists": "list",
    "dictionary": "dict",
    "hashmap": "dict",
    "map": "dict",
    "booleans": "bool",
    "boolean": "bool",
}


def _canonical_token(token: str) -> str:
    normalized = NUMBER_WORD_MAP.get(token, token)
    return SYNONYM_WORD_MAP.get(normalized, normalized)


def _answer_tokens(text: str) -> List[str]:
    raw_tokens = re.findall(r"[a-zA-Z_][a-zA-Z0-9_]*|\d+", text.lower())
    return [_canonical_token(token) for token in raw_tokens]


def _key_tokens(text: str) -> List[str]:
    stop = {
        "a", "an", "and", "as", "at", "be", "for", "from", "if", "in", "is", "it", "of", "on",
        "or", "that", "the", "to", "with", "what", "which", "should", "named", "returns", "return",
    }
    seen: set[str] = set()
    keys: List[str] = []
    for token in _answer_tokens(text):
        if token in stop:
            continue
        if len(token) == 1 and not token.isdigit():
            continue
        if token not in seen:
            keys.append(token)
            seen.add(token)
    return keys


def _code_answer_matches(user_answer: str, correct_answer: str) -> bool:
    user_norm = _normalize_code_answer(user_answer)
    correct_norm = _normalize_code_answer(correct_answer)

    if user_norm == correct_norm:
        return True

    if len(user_norm) >= 6 and (user_norm in correct_norm or correct_norm in user_norm):
        return True

    user_keys = set(_key_tokens(user_norm))
    correct_keys = set(_key_tokens(correct_norm))

    if not correct_keys:
        return False

    overlap = len(user_keys & correct_keys)
    ratio = overlap / len(correct_keys)
    if overlap >= 2 and ratio >= 0.5:
        return True

    if len(correct_keys) == 1 and overlap == 1:
        return True

    return False


def ask_step_code(step: StepQuestion, scenario_prompt: str) -> tuple[bool, int, bool]:
    hint_count = 0
    used_hint_once = False
    correct_answer = step.choices[step.answer_index]

    print(color_text("\n─" * 0))
    print_rule("─", MAGENTA)
    print(color_text("Problem", BOLD, MAGENTA))
    print(color_text(scenario_prompt, BLUE))
    print_rule("─", DIM)
    print(color_text(step.prompt, BOLD))
    clue_words = _key_tokens(correct_answer)[:4]
    clue_text = ", ".join(clue_words) if clue_words else step.hint
    print(color_text(f"Clue in question: {step.hint}", DIM, CYAN))
    print(color_text(f"Keyword clue: {clue_text}", DIM, CYAN))
    print()

    while True:
        answer = input("Write your code answer (H for hint, Q to quit/save): ").strip()
        upper = answer.upper()
        if upper == "Q":
            return False, hint_count, True
        if upper == "H":
            print(f"\nHint: {step.hint}")
            print(f"Keyword clue: {clue_text}\n")
            if not used_hint_once:
                hint_count += 1
                used_hint_once = True
            continue
        if not answer:
            print("\nPlease type an answer, H, or Q.\n")
            continue

        is_correct = _code_answer_matches(answer, correct_answer)
        if is_correct:
            print(f"\n{GREEN}Correct.{RESET}")
        else:
            print(
                f"\n{YELLOW}Incorrect. Expected answer:{RESET} {correct_answer}"
            )
        print(f"Why: {step.explanation}\n")
        return is_correct, hint_count, False


