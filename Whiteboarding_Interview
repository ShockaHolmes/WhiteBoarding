def generate_hard_pool() -> List[Scenario]:
    pool = []

    for i in range(1, 26):
        pool.append(build_hard_class_counter(f"Counter{i}"))
        pool.append(build_hard_two_sum(f"two_sum_{i}"))
        pool.append(build_hard_binary_search(f"binary_search_{i}"))
        pool.append(build_hard_valid_parentheses(f"is_balanced_{i}"))
        pool.append(build_hard_has_duplicate(f"has_duplicate_{i}"))

    return pool


def generate_hard_pool_for_language(language: str) -> List[Scenario]:
    if language == "python":
        return generate_hard_pool()

    pool = []
    suffix = "java" if language == "java" else "cs"
    class_prefix = "JavaCounter" if language == "java" else "CsCounter"

    for i in range(1, 26):
        pool.append(localize_scenario(build_hard_class_counter(f"{class_prefix}{i}"), language))
        pool.append(localize_scenario(build_hard_two_sum(f"{suffix}_two_sum_{i}"), language))
        pool.append(localize_scenario(build_hard_binary_search(f"{suffix}_binary_search_{i}"), language))
        pool.append(localize_scenario(build_hard_valid_parentheses(f"{suffix}_is_balanced_{i}"), language))
        pool.append(localize_scenario(build_hard_has_duplicate(f"{suffix}_has_duplicate_{i}"), language))

    return pool


def get_pool(level: str, language: str = "python") -> List[Scenario]:
    if level == "easy":
        return generate_easy_pool_for_language(language)
    elif level == "medium":
        return generate_medium_pool_for_language(language)
    return generate_hard_pool_for_language(language)


def play_scenario(
    scenario: Scenario,
    state: Dict,
    category_stats: Dict[str, Dict[str, int]],
    start_step: int = 0,
    answer_handler: Callable[[StepQuestion, str], tuple[bool, int, bool]] = ask_step,
) -> tuple[bool, int]:
    print_banner(f"INTERVIEW SCENARIO: {scenario.title}", f"Category: {scenario.category}")
    print_panel(
        "Round Status",
        [
            f"Prompt: {scenario.prompt}",
            f"Hearts: {hearts_text(state['hearts'])}",
            f"Current Score: {format_score(state['score'], state['possible'])}",
            f"Current Streak: {color_text(str(state['streak']), BOLD, YELLOW)}",
        ],
        accent=CYAN,
    )

    scenario_correct = 0
    scenario_possible = 0

    if scenario.category not in category_stats:
        category_stats[scenario.category] = {"earned": 0, "possible": 0}

    for step_index in range(start_step, len(scenario.steps)):
        step = scenario.steps[step_index]
        is_correct, hints_used, wants_quit = answer_handler(step, scenario.prompt)
        if wants_quit:
            return False, step_index

        state["hints_used"] += hints_used
        state["possible"] += 10
        scenario_possible += 10
        category_stats[scenario.category]["possible"] += 10

        if is_correct:
            state["score"] += 10
            scenario_correct += 10
            category_stats[scenario.category]["earned"] += 10
            state["streak"] += 1

            if state["streak"] > 0 and state["streak"] % 3 == 0:
                state["score"] += 5
                state["bonus"] += 5
                print(color_text("Streak bonus: +5 points", BOLD, GREEN))
        else:
            state["hearts"] = max(0, state["hearts"] - 1)
            state["streak"] = 0
            print(color_text(f"Heart lost. Hearts now: {hearts_text(state['hearts'])}", BOLD, RED))

        print_rule("─", DIM)

    if scenario_correct == scenario_possible and state["hearts"] < STARTING_HEARTS:
        state["hearts"] += 1
        print(color_text("Perfect scenario. You regained 1 heart.", BOLD, GREEN))

    print_panel(
        "Scenario Complete",
        [
            f"Scenario Score: {format_score(scenario_correct, scenario_possible)}",
            f"Overall Score: {format_score(state['score'], state['possible'])}",
            f"Hearts: {hearts_text(state['hearts'])}",
        ],
        accent=GREEN,
    )
    return True, len(scenario.steps)


def print_category_breakdown(category_stats: Dict[str, Dict[str, int]]) -> None:
    print_banner("CATEGORY BREAKDOWN")
    for category, stats in sorted(category_stats.items()):
        earned = stats["earned"]
        possible = stats["possible"]
        percent = (earned / possible * 100) if possible else 0
        print(f"{category:<15} {earned:>3}/{possible:<3}  {color_text(f'{percent:>6.1f}%', BOLD, CYAN)}")


def play_game() -> None:
    print_banner("WHITEBOARD INTERVIEW GAME", "Step-by-step coding interview practice")
    print_panel(
        "How It Works",
        [
            "You will play through 10 interview-style coding scenarios.",
            "Each scenario breaks the problem into guided multiple-choice steps.",
            f"Use {color_text('H', BOLD, YELLOW)} for a hint and {color_text('Q', BOLD, RED)} to quit/save.",
        ],
        accent=BLUE,
    )

    saved = load_saved_game()

    if saved:
        resume = input(color_text("Saved game found. Resume where you left off? (y/n): ", BOLD, MAGENTA)).strip().lower()
    else:
        resume = "n"

    if saved and resume == "y":
        name = saved.get("name", "Player")
        level = saved.get("level", "easy")
        language = saved.get("language", "python")
        state = saved.get("state", {
            "score": 0,
            "possible": 0,
            "bonus": 0,
            "streak": 0,
            "hearts": STARTING_HEARTS,
            "hints_used": 0,
        })
        category_stats = saved.get("category_stats", {})
        selected_indices = saved.get("selected_indices", [])
        scenario_position = int(saved.get("scenario_position", 0))
        step_position = int(saved.get("step_position", 0))
        print(color_text("Resuming saved game.", BOLD, GREEN))
    else:
        if saved:
            clear_saved_game()
        name = ask_player_name()
        language = ask_language()
        level = ask_level()
        state = {
            "score": 0,
            "possible": 0,
            "bonus": 0,
            "streak": 0,
            "hearts": STARTING_HEARTS,
            "hints_used": 0,
        }
        category_stats: Dict[str, Dict[str, int]] = {}
        pool = get_pool(level, language)
        if len(pool) < 100:
            raise ValueError(f"{level} level must have at least 100 prepared scenarios.")
        selected_indices = random.sample(range(len(pool)), SESSION_SCENARIOS)
        scenario_position = 0
        step_position = 0

    while True:
        pool = get_pool(level, language)
        if len(pool) < 100:
            raise ValueError(f"{level} level must have at least 100 prepared scenarios.")

        if len(selected_indices) != SESSION_SCENARIOS:
            selected_indices = random.sample(range(len(pool)), SESSION_SCENARIOS)
            scenario_position = 0
            step_position = 0

        selected = [pool[i] for i in selected_indices]

        for i in range(scenario_position, SESSION_SCENARIOS):
            scenario = selected[i]
            print_banner(f"Scenario {i + 1} of {SESSION_SCENARIOS}")
            completed, next_step = play_scenario(
                scenario,
                state,
                category_stats,
                start_step=step_position if i == scenario_position else 0,
            )
            if not completed:
                save_game_progress(
                    name,
                    level,
                    language,
                    state,
                    category_stats,
                    selected_indices,
                    i,
                    next_step,
                )
                print(color_text("\nProgress saved. Run the game again to continue later.", BOLD, MAGENTA))
                return

            scenario_position = i + 1
            step_position = 0

        percent = round((state["score"] / state["possible"]) * 100, 1) if state["possible"] else 0

        print_banner("SESSION COMPLETE", f"Player: {name}")
        print_panel(
            "Final Summary",
            [
                f"Level: {level_badge(level)}",
                f"Question Language: {color_text(LANGUAGE_DISPLAY.get(language, language), BOLD, MAGENTA)}",
                f"Final Score: {format_score(state['score'], state['possible'])}",
                f"Percent: {color_text(f'{percent}%', BOLD, GREEN if percent >= 75 else YELLOW)}",
                f"Bonus Points Earned: {color_text(str(state['bonus']), BOLD, CYAN)}",
                f"Hints Used: {color_text(str(state['hints_used']), BOLD, YELLOW)}",
                f"Hearts Left: {state['hearts']} {hearts_text(state['hearts'])}",
            ],
            accent=GREEN,
        )

        if percent >= 90:
            print(color_text("Excellent interview-style performance.", BOLD, GREEN))
        elif percent >= 75:
            print(color_text("Strong work. You are building real whiteboarding muscle.", BOLD, CYAN))
        elif percent >= 60:
            print(color_text("Good effort. Review the explanations and run it again.", BOLD, YELLOW))
        else:
            print(color_text("Keep practicing. The step-by-step format will help you improve quickly.", BOLD, RED))

        print_category_breakdown(category_stats)
        clear_saved_game()

        print(color_text("\nThank you for playing.", BOLD, MAGENTA))
        continue_game = input(color_text("Do you want to continue to another round? (y/n): ", BOLD)).strip().lower()

        if continue_game == "y":
            selected_indices = random.sample(range(len(pool)), SESSION_SCENARIOS)
            scenario_position = 0
            step_position = 0
            continue

        leaderboard = update_leaderboard(name, state["score"], state["possible"], level, state["hints_used"])
        print_leaderboard(leaderboard)
        print(color_text("Goodbye.", BOLD, BLUE))
        return


