def ask_practice_topic() -> tuple[str, str]:
    """Returns (display_name, topic_key)."""
    topic_list = list(PRACTICE_TOPICS.items())
    print_panel(
        "Choose a Practice Topic",
        [f"  {color_text(str(i+1)+'.', BOLD, CYAN)} {name}" for i, (name, _) in enumerate(topic_list)],
        accent=MAGENTA,
    )
    while True:
        raw = input(color_text(f"Enter a number (1-{len(topic_list)}): ", BOLD)).strip()
        if raw.isdigit() and 1 <= int(raw) <= len(topic_list):
            idx = int(raw) - 1
            display, key = topic_list[idx]
            return display, key
        print(color_text(f"Please enter a number between 1 and {len(topic_list)}.", YELLOW))


def play_practice_mode() -> None:
    print_banner("PRACTICE MODE", "Focused topic drills — 5 questions per session")

    name = ask_player_name()
    language = ask_language()
    level = ask_level()

    while True:
        display_name, topic_key = ask_practice_topic()

        builders = PRACTICE_QUESTION_BUILDERS.get(topic_key, {})
        builder = builders.get(level)
        if builder is None:
            print(color_text("No questions available for that combination yet.", YELLOW))
            continue

        questions = builder(language)
        random.shuffle(questions)
        questions = questions[:5]

        state = {
            "score": 0,
            "possible": 0,
            "bonus": 0,
            "streak": 0,
            "hearts": STARTING_HEARTS,
            "hints_used": 0,
        }
        category_stats: Dict[str, Dict[str, int]] = {}

        lang_display = LANGUAGE_DISPLAY.get(language, language)
        scenario = Scenario(
            level=level,
            category=display_name,
            title=f"Practice: {display_name} ({lang_display})",
            prompt=f"Practice drill — {display_name} — {level.title()} — {lang_display}",
            steps=questions,
        )

        print_banner(f"Practice: {display_name}", f"Level: {level.title()}  |  Language: {lang_display}")
        completed, _ = play_scenario(scenario, state, category_stats)

        score = state["score"]
        possible = state["possible"]
        percent = round((score / possible) * 100, 1) if possible else 0

        print_panel(
            "Practice Session Summary",
            [
                f"Topic:    {color_text(display_name, BOLD, CYAN)}",
                f"Level:    {level_badge(level)}",
                f"Language: {color_text(lang_display, BOLD, MAGENTA)}",
                f"Score:    {format_score(score, possible)}  ({color_text(f'{percent}%', BOLD, GREEN if percent >= 80 else YELLOW)})",
                f"Hints:    {state['hints_used']}",
                f"Hearts:   {hearts_text(state['hearts'])}",
            ],
            accent=GREEN,
        )

        if percent == 100:
            print(color_text("Perfect score! You have mastered this topic at this level.", BOLD, GREEN))
        elif percent >= 80:
            print(color_text("Great work! Keep practicing to lock this in.", BOLD, CYAN))
        elif percent >= 60:
            print(color_text("Good effort. Review the explanations and try again.", BOLD, YELLOW))
        else:
            print(color_text("Keep going — read the explanations carefully and retry.", BOLD, RED))

        leaderboard = update_leaderboard(
            f"{name} [Practice:{display_name}]",
            score,
            possible,
            level,
            state["hints_used"],
        )
        print_leaderboard(leaderboard)

        again = input(color_text("\nPractice another topic? (y/n): ", BOLD)).strip().lower()
        if again != "y":
            print(color_text("Returning to main menu.", BOLD, BLUE))
            return


