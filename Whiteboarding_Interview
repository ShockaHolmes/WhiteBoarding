@dataclass
class StepQuestion:
    prompt: str
    choices: List[str]
    answer_index: int
    hint: str
    explanation: str


@dataclass
class Scenario:
    level: str
    category: str
    title: str
    prompt: str
    steps: List[StepQuestion]


def make_step(prompt: str, correct: str, wrongs: List[str], hint: str, explanation: str) -> StepQuestion:
    clean_wrongs = []
    for item in wrongs:
        if item != correct and item not in clean_wrongs:
            clean_wrongs.append(item)

    choices = [correct] + clean_wrongs[:3]
    random.shuffle(choices)
    answer_index = choices.index(correct)
    return StepQuestion(
        prompt=prompt,
        choices=choices,
        answer_index=answer_index,
        hint=hint,
        explanation=explanation,
    )


def hearts_text(hearts: int) -> str:
    full = "❤️" * max(0, hearts)
    empty = "🖤" * max(0, STARTING_HEARTS - hearts)
    return full + empty


def color_text(text: str, *styles: str) -> str:
    return "".join(styles) + text + RESET


def terminal_width() -> int:
    return max(72, min(shutil.get_terminal_size((72, 20)).columns, 100))


def print_rule(char: str = "═", style: str = CYAN) -> None:
    print(color_text(char * terminal_width(), style))


def print_banner(title: str, subtitle: Optional[str] = None) -> None:
    width = terminal_width()
    print()
    print(color_text("╔" + "═" * (width - 2) + "╗", CYAN))
    print(color_text(f"║{title.center(width - 2)}║", CYAN, BOLD))
    if subtitle:
        print(color_text(f"║{subtitle.center(width - 2)}║", BLUE))
    print(color_text("╚" + "═" * (width - 2) + "╝", CYAN))


def print_panel(title: str, lines: List[str], accent: str = BLUE) -> None:
    width = terminal_width()
    print(color_text(f"\n{title}", accent, BOLD))
    print(color_text("─" * width, accent))
    for line in lines:
        print(line)


def format_score(score: int, possible: int) -> str:
    return color_text(f"{score}/{possible}", BOLD, CYAN)


def level_badge(level: str) -> str:
    palette = {
        "easy": GREEN,
        "medium": YELLOW,
        "hard": RED,
    }
    return color_text(level.title(), BOLD, palette.get(level, CYAN))


def load_leaderboard() -> List[Dict]:
    if not os.path.exists(LEADERBOARD_FILE):
        return []
    try:
        with open(LEADERBOARD_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            return data if isinstance(data, list) else []
    except (json.JSONDecodeError, OSError):
        return []


def save_leaderboard(entries: List[Dict]) -> None:
    with open(LEADERBOARD_FILE, "w", encoding="utf-8") as f:
        json.dump(entries[:10], f, indent=2)


def load_saved_game() -> Optional[Dict]:
    if not os.path.exists(SAVE_FILE):
        return None
    try:
        with open(SAVE_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            return data if isinstance(data, dict) else None
    except (json.JSONDecodeError, OSError):
        return None


def save_game_progress(
    name: str,
    level: str,
    language: str,
    state: Dict,
    category_stats: Dict[str, Dict[str, int]],
    selected_indices: List[int],
    scenario_position: int,
    step_position: int,
) -> None:
    payload = {
        "name": name,
        "level": level,
        "language": language,
        "state": state,
        "category_stats": category_stats,
        "selected_indices": selected_indices,
        "scenario_position": scenario_position,
        "step_position": step_position,
    }
    with open(SAVE_FILE, "w", encoding="utf-8") as f:
        json.dump(payload, f, indent=2)


def clear_saved_game() -> None:
    if os.path.exists(SAVE_FILE):
        try:
            os.remove(SAVE_FILE)
        except OSError:
            pass


def update_leaderboard(name: str, score: int, possible: int, level: str, hints_used: int) -> List[Dict]:
    percent = round((score / possible) * 100, 1) if possible else 0
    entries = load_leaderboard()
    entries.append({
        "name": name,
        "score": score,
        "possible": possible,
        "percent": percent,
        "level": level,
        "hints_used": hints_used
    })
    entries.sort(key=lambda x: (x["score"], x["percent"], -x["hints_used"]), reverse=True)
    save_leaderboard(entries)
    return entries[:10]


def print_leaderboard(entries: List[Dict]) -> None:
    print_banner("LEADERBOARD", "Top 10 Runs")
    if not entries:
        print(color_text("No leaderboard entries yet.", DIM))
        return
    for i, entry in enumerate(entries, start=1):
        medal = color_text(f"#{i}", BOLD, MAGENTA if i <= 3 else BLUE)
        print(
