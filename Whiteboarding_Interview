def main_menu() -> None:
    while True:
        print_banner("WHITEBOARD INTERVIEW GAME", "Your coding interview practice companion")
        print_panel(
            "Main Menu",
            [
                f"  {color_text('1.', BOLD, CYAN)} Classic Mode  — 10 random interview scenarios",
                f"  {color_text('2.', BOLD, CYAN)} Practice Mode — Choose a topic, drill 5 questions",
                f"  {color_text('3.', BOLD, CYAN)} Code Write Mode — Type each answer (no multiple choice)",
                f"  {color_text('4.', BOLD, CYAN)} View Leaderboard",
                f"  {color_text('5.', BOLD, RED)}  Quit",
            ],
            accent=MAGENTA,
        )
        choice = input(color_text("Enter 1, 2, 3, 4, or 5: ", BOLD)).strip()
        if choice == "1":
            play_game()
        elif choice == "2":
            play_practice_mode()
        elif choice == "3":
            play_code_mode()
        elif choice == "4":
            entries = load_leaderboard()
            print_leaderboard(entries)
            input(color_text("\nPress Enter to continue...", DIM))
        elif choice == "5":
            print(color_text("Goodbye!", BOLD, BLUE))
            return
        else:
            print(color_text("Please enter 1, 2, 3, 4, or 5.", YELLOW))


if __name__ == "__main__":
    main_menu()